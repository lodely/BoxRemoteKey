<resources>
    <!-- Base application theme using Material Design -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorPrimaryDark">@color/md_theme_primary</item>
        <item name="colorAccent">@color/accent_primary</item>
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="android:statusBarColor">@color/md_theme_primary</item>
        <item name="android:colorControlHighlight">#4242A5F5</item>
        <item name="android:windowBackground">@color/md_theme_background</item>
        <item name="android:textColorPrimary">@color/md_theme_onBackground</item>
        <item name="android:textColorSecondary">@color/md_theme_secondary</item>
        <item name="buttonStyle">@style/Widget.AppCompat.Button.Colored</item>
    </style>

    <!-- Theme for video player (fullscreen) -->
    <style name="PlayerTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Keyboard normal key (letters, numbers) -->
    <style name="kb_key_normal">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#212121</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:background">@drawable/kb_key_normal</item>
        <item name="android:onClick">onClick</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Keyboard modifier key (退格, 符, A/a, 中/EN) -->
    <style name="kb_key_alt">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#5F6368</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:background">@drawable/kb_key_alt</item>
        <item name="android:onClick">onClick</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Keyboard accent key (Enter/回车) -->
    <style name="kb_key_accent">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:background">@drawable/kb_key_accent</item>
        <item name="android:onClick">onClick</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="kb_key_delete">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:background">@drawable/kb_key_delete</item>
        <item name="android:onClick">onClick</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Keyboard icon key (← →) -->
    <style name="kb_key_icon">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:background">@drawable/kb_key_alt</item>
        <item name="android:focusable">true</item>
        <item name="android:scaleType">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:tint">#5F6368</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Card style for sections -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Primary button style -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="android:textColor">@color/md_theme_onPrimary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Secondary button style -->
    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="strokeColor">@color/md_theme_primary</item>
        <item name="android:textColor">@color/md_theme_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Text input style -->
    <style name="TextInputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="boxStrokeColor">@color/md_theme_primary</item>
        <item name="hintTextColor">@color/md_theme_primary</item>
        <item name="android:textColorHint">@color/md_theme_secondary</item>
    </style>

    <!-- Section title style -->
    <style name="SectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_theme_onBackground</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Body text style -->
    <style name="BodyText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/md_theme_onBackground</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- Caption text style -->
    <style name="CaptionText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/md_theme_secondary</item>
    </style>
</resources>